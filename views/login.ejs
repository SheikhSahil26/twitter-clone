<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Sign in to X</title>
  <style>
    @import url('https://cdn.googleapis.com');

    body {
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body class="bg-black text-white min-h-screen flex flex-col antialiased">

  <!-- Top Navigation Bar -->
  <header class="flex items-center px-4 py-3 sticky top-0 bg-black/80 backdrop-blur-md z-50">
    <div class="flex-1 flex justify-center">
      <svg viewBox="0 0 24 24" class="h-8 w-8 fill-white">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
      </svg>
    </div>
    <!-- Removed w-10 spacer for cleaner header on small screens -->
  </header>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col items-center justify-start pt-12 px-6">
    <div class="w-full max-w-[364px] flex flex-col">

      <h1 class="text-[31px] font-bold mb-8 tracking-tight">Sign in to X</h1>

      <!-- Social Login Buttons -->
     
        <form id="loginForm" class="flex flex-col gap-4">
          <!-- Username Input -->
          <div class="relative w-full border border-gray-800 rounded-[4px] focus-within:ring-1 focus-within:ring-[#1d9bf0] focus-within:border-[#1d9bf0] transition-shadow group">
            <input type="text" id="userInput" name="email" required
              class="w-full bg-black px-3 pt-6 pb-2 text-white text-[17px] focus:outline-none peer placeholder-transparent"
              placeholder="Phone, email, or username">
            <label for="userInput" class="absolute left-3 top-4 text-[#71767b] text-[17px] transition-all pointer-events-none
                          peer-placeholder-shown:top-4 peer-placeholder-shown:text-[17px] 
                          peer-focus:top-1.5 peer-focus:text-[13px] peer-focus:text-[#1d9bf0]
                          peer-not-placeholder-shown:top-1.5 peer-not-placeholder-shown:text-[13px]">
              Phone, email, or username
            </label>
          </div>

          <!-- Password Input -->
          <div class="relative w-full border border-gray-800 rounded-[4px] focus-within:ring-1 focus-within:ring-[#1d9bf0] focus-within:border-[#1d9bf0] transition-shadow group">
            <input type="password" id="passwordInput" name="password" required
              class="w-full bg-black px-3 pt-6 pb-2 text-white text-[17px] focus:outline-none peer placeholder-transparent"
              placeholder="Password">
            <label for="passwordInput" class="absolute left-3 top-4 text-[#71767b] text-[17px] transition-all pointer-events-none
                          peer-placeholder-shown:top-4 peer-placeholder-shown:text-[17px] 
                          peer-focus:top-1.5 peer-focus:text-[13px] peer-focus:text-[#1d9bf0]
                          peer-not-placeholder-shown:top-1.5 peer-not-placeholder-shown:text-[13px]">
              Password
            </label>
          </div>
          <input type="checkbox" id="remember-me" name="rememberMe">
          <label for="rememberMe">remember me</label>

          <!-- Sign In Button -->
          <button type="button" id="btn"
            class="w-full bg-white text-black font-bold py-2.5 rounded-full mt-4 hover:bg-[#d7dbdc] active:scale-[0.98] transition-all duration-200">
            Sign in
          </button>
        </form>

        <!-- Forgot Password -->
        <a href="/forgot-password"><button class="w-full border border-gray-700 text-white font-bold py-2 rounded-full mt-2 hover:bg-white/10 transition-colors text-[15px]">
          Forgot password?
        </button></a>

        <!-- Footer Link -->
        <p class="text-[#71767b] mt-10 text-[15px]">
          Don't have an account? <a href="/signup" class="text-[#1d9bf0] hover:underline decoration-1 underline-offset-2">Sign up</a>
        </p>
      </div>
    </div>
  </main>

</body>

<script>

  



  const form = document.getElementById("loginForm")

  const submitBtn = document.getElementById("btn");

  submitBtn.addEventListener("click", login)

  async function login(e) {

    const data = new FormData(form)
    const values = Object.fromEntries(data.entries())
    console.log(data);
    console.log(values);

    if(values.rememberMe==="on"){
      values.rememberMe=true;
    }
    else{
      values.rememberMe=false;
    }

    if (!validateForm()) {
      e.preventDefault();
      console.log("prevented form submission")
      return;
    }


    const res = await fetch("/api/auth/login", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(values)
    })

    console.log(res, "response")

    const data1 = await res.json()
    console.log(data1)

    if (data1.error) {
      alert(data1.error)
    }
    else{
      
          localStorage.setItem("accessToken",data1.token);
      
         
          window.location.href =`/feed`
          // window.location.href = "/login"

    }


  }

  function validateForm() {
    return true;
  }

</script>




</html>