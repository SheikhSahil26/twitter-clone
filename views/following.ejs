<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>People / X</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://cdn.googleapis.com');
    body { font-family: 'Inter', sans-serif; }
    .tab-active { border-bottom: 4px solid #1d9bf0; font-weight: 700; color: white !important; }
  </style>
</head>
<body class="bg-black text-white min-h-screen antialiased flex justify-center">

  <!-- Main Container -->
  <main class="w-full max-w-[600px] border-x border-gray-800 min-h-screen pb-20">
    
    <!-- Top Header -->
    <header class="sticky top-0 bg-black/80 backdrop-blur-md z-50">
      <div class="flex items-center px-4 py-1">
        <div class="p-2 hover:bg-white/10 rounded-full cursor-pointer transition-colors mr-6">
          <svg viewBox="0 0 24 24" class="h-5 w-5 fill-white"><path d="M7.414 13l5.043 5.04-1.414 1.42L3.586 12l7.457-7.46 1.414 1.42L7.414 11H21v2H7.414z"></path></svg>
        </div>
        <div>
          <h2 class="text-xl font-bold leading-tight" id="header-name">User Name</h2>
          <p class="text-[13px] text-[#71767b]">@username</p>
        </div>
      </div>

      <!-- Tabs Navigation -->
      <nav class="flex border-b border-gray-800 mt-2">
        <button onclick="switchTab('followers')" id="tab-followers" class="flex-1 py-4 text-[#71767b] hover:bg-white/10 transition-colors text-[15px] tab-active">
            Followers
        </button>
        
      </nav>
    </header>

  <div id="following-container"></div>

  </main>

  <script>
   const username = "<%= username%>"
    console.log(username,"username")

    async function getFollowers(){
        const res = await fetch(`/api/user/get-user-followings/${username}`,{
            method:"GET",
            headers:{
                authorization:`Bearer ${localStorage.getItem("accessToken")}`
            }
        })

        const data = await res.json()

        console.log(data,"user followers!!!!");


        const followingContainer = document.getElementById("following-container");

        const followers = data.followings

        followers.forEach((following,idx) => {
            const isFollowed = Boolean(Number(following.is_followed));
            const followerDiv = document.createElement("div")
            const followerContent = ` <div class="px-4 py-3 flex items-start gap-3 hover:bg-white/[0.03] transition-colors cursor-pointer">
                  <a href="/profile/${following.username}">
                <img src="${following.profile_photo_url}" class="h-10 w-10 rounded-full bg-gray-700" alt="Avatar">
                
                <div class="flex-1">
                    <div class="flex items-center justify-between">
                      
                        <div class="flex flex-col">
                            <span class="font-bold hover:underline leading-tight">${following.username}</span>
                            <span class="text-[#71767b] text-[15px]">@${following.username}</span>
                        </div>
                        </a>
                        <button id="follow-unfollow-button-${idx}"
                            onclick="followUnfollow('${following.username}',${idx})"
                            class="${isFollowed 
                                ? 'bg-black border border-gray-600 text-white hover:border-red-600 hover:text-red-600 hover:bg-red-600/10' 
                                : 'bg-white text-black'} 
                                min-w-[100px] font-bold py-1.5 px-4 rounded-full text-[14px] transition-all"
                        >${isFollowed ? "unfollow" : "follow"}</button>
                    </div>
                    <p class="text-[15px] mt-1 text-white">This is a short bio for @${following.username}...</p>
                </div>
            </div>`

            followerDiv.innerHTML = followerContent;

            followingContainer.append(followerDiv)

        });






    }

    getFollowers();


     async function followUnfollow(username,idx){
        console.log(username)
      const res = await fetch(`/api/user/follow-unfollow-user/${username}`, {
            method: "POST",
            headers: {
                authorization: `Bearer ${localStorage.getItem("accessToken")}`
            }
        })

        const followBtn = document.getElementById(`follow-unfollow-button-${idx}`)

        const data = await res.json();
        console.log(data, "follow unfollow status")

        if(data.is_followed !== undefined){
            followBtn.innerText = data.is_followed ? "unfollow" : "follow"
            followBtn.className = `${data.is_followed 
                ? 'bg-black border border-gray-600 text-white hover:border-red-600 hover:text-red-600 hover:bg-red-600/10' 
                : 'bg-white text-black'} min-w-[100px] font-bold py-1.5 px-4 rounded-full text-[14px] transition-all`
        }

    }




  </script>
</body>
</html>
