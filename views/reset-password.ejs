<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset password / X</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://cdn.googleapis.com');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-black text-white min-h-screen flex flex-col antialiased">

  <!-- Top Navigation Bar -->
  <header class="flex items-center px-4 py-3 sticky top-0 bg-black/80 backdrop-blur-md z-50">
    <div class="flex-1 flex justify-center">
      <svg viewBox="0 0 24 24" class="h-8 w-8 fill-white">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
      </svg>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col items-center justify-start pt-12 px-6">
    <div class="w-full max-w-[364px] flex flex-col">

      <h1 class="text-[31px] font-bold mb-3 tracking-tight">Choose a new password</h1>
      <p class="text-[#71767b] text-[15px] mb-8 leading-5">
        Make sure your new password is at least 8 characters long and hard to guess.
      </p>

      <form id="resetForm" class="flex flex-col gap-6">
        <!-- New Password Input -->
        <div class="relative w-full border border-gray-800 rounded-[4px] focus-within:ring-1 focus-within:ring-[#1d9bf0] focus-within:border-[#1d9bf0] transition-shadow group">
          <input type="password" id="password" name="password" required
            class="w-full bg-black px-3 pt-6 pb-2 text-white text-[17px] focus:outline-none peer placeholder-transparent"
            placeholder="New password">
          <label for="password" class="absolute left-3 top-4 text-[#71767b] text-[17px] transition-all pointer-events-none
                        peer-placeholder-shown:top-4 peer-placeholder-shown:text-[17px] 
                        peer-focus:top-1.5 peer-focus:text-[13px] peer-focus:text-[#1d9bf0]
                        peer-not-placeholder-shown:top-1.5 peer-not-placeholder-shown:text-[13px]">
            New password
          </label>
        </div>

        <!-- Confirm Password Input -->
        <div class="relative w-full border border-gray-800 rounded-[4px] focus-within:ring-1 focus-within:ring-[#1d9bf0] focus-within:border-[#1d9bf0] transition-shadow group">
          <input type="password" id="confirmPassword" name="confirmPassword" required
            class="w-full bg-black px-3 pt-6 pb-2 text-white text-[17px] focus:outline-none peer placeholder-transparent"
            placeholder="Confirm password">
          <label for="confirmPassword" class="absolute left-3 top-4 text-[#71767b] text-[17px] transition-all pointer-events-none
                        peer-placeholder-shown:top-4 peer-placeholder-shown:text-[17px] 
                        peer-focus:top-1.5 peer-focus:text-[13px] peer-focus:text-[#1d9bf0]
                        peer-not-placeholder-shown:top-1.5 peer-not-placeholder-shown:text-[13px]">
            Confirm password
          </label>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col gap-3 mt-4">
            <button type="button" id="resetBtn"
                class="w-full bg-white text-black font-bold py-2.5 rounded-full hover:bg-[#d7dbdc] active:scale-[0.98] transition-all duration-200">
                Reset password
            </button>
        </div>
      </form>
    </div>
  </main>
  </body>
    <script>

        const token =  "<%= token %>";

        console.log(token,"token for reset password!!")


        async function verifyToken(){
            const res = await fetch(`/api/auth/verify-token/${token}`,{
                method:"GET",
                
                
            })

            const data = await res.json();

            console.log(data,"");

            if(data.error){
                alert("invalid token")
                window.location.href="/login"
            }

        }

        verifyToken();



    const resetBtn = document.getElementById("resetBtn")
    resetBtn.addEventListener("click", resetPassword)

    async function resetPassword(){

       const resetForm = document.getElementById("resetForm");
       const data = new FormData(resetForm)
         const values = Object.fromEntries(data.entries())
        console.log(data)
        console.log(values);

        console.log(values)

        if(values.password !== values.confirmPassword){
            alert("both pass are not same")
            return;
        }



        delete values["confirmPassword"]

        values.token = token

        console.log(values)

      
        const res = await fetch(`/api/auth/reset-password`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body:JSON.stringify(values),
        })


        const respData = await res.json();

        console.log(respData,"res data")

        if (respData.error) {
            alert(respData.error);
        }
        else{
            alert(respData.message);
            window.location.href="/login"
        }

      
    }





    </script>


</html>