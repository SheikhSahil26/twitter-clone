<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile / X</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://cdn.googleapis.com');
    body { font-family: 'Inter', sans-serif; }
    /* Custom scrollbar for dark theme */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #000; }
    ::-webkit-scrollbar-thumb { background: #2f3336; border-radius: 4px; }
  </style>
</head>
<body class="bg-black text-white min-h-screen antialiased flex justify-center">

  <!-- Main Container (Centered like X Desktop) -->
  <main class="w-full max-w-[600px] border-x border-gray-800 min-h-screen pb-20">
    
          <!-- Top Header -->
        <header class="flex items-center px-4 py-1 sticky top-0 bg-black/80 backdrop-blur-md z-40">
            <div class="p-2 hover:bg-white/10 rounded-full cursor-pointer transition-colors mr-6">
                <svg viewBox="0 0 24 24" class="h-5 w-5 fill-white">
                    <path d="M7.414 13l5.043 5.04-1.414 1.42L3.586 12l7.457-7.46 1.414 1.42L7.414 11H21v2H7.414z">
                    </path>
                </svg>
            </div>
            <div>
                <h2 class="text-xl font-bold leading-tight">User Name</h2>
                <p class="text-[13px] text-[#71767b]">0 Posts</p>
            </div>
        </header>

        <!-- Banner Image -->
        <div class="h-48 w-full bg-[#333639] relative">
            <!-- Replace src with actual banner URL -->
            <img src="https://unsplash.com" id="banner-image" class="w-full h-full object-cover" alt="Banner">
        </div>

        <!-- Profile Info Section -->
        <div class="px-4 relative mb-4">
            <!-- Profile Picture -->
            <div class="absolute -top-16 left-4">
                <div class="h-32 w-32 rounded-full border-4 border-black bg-[#16181c] overflow-hidden">
                    <img id="profile-image" src="https://twimg.com" alt="Avatar" class="w-full h-full">
                </div>
            </div>

           
            <!-- Bio & Stats -->
            <div class="mt-8">
                <div>
                    <h1 id="username" class="text-xl font-extrabold leading-tight"></h1>
                    <p class="text-[#71767b]">@username</p>
                </div>

                <div id="bio" class="mt-3 text-[15px] leading-normal">
                    This is where your bio goes. Highlighting your interests, work, or just a quick quote. <span
                        class="text-[#1d9bf0]">#X</span>
                </div>

                <div  class="flex flex-wrap gap-x-4 gap-y-1 mt-3 text-[#71767b] text-[15px]">
                    <span id="joined" class="flex items-center gap-1">
                        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                            <path
                                d="M7 4V3h2v1h6V3h2v1h1.5C19.88 4 21 5.12 21 6.5v12c0 1.38-1.12 2.5-2.5 2.5h-13C4.12 21 3 19.88 3 18.5v-12C3 5.12 4.12 4 5.5 4H7zm0 2H5.5c-.28 0-.5.22-.5.5v12c0 .28.22.5.5.5h13c.28 0 .5-.22.5-.5v-12c0-.28-.22-.5-.5-.5H17v1h-2V6H9v1H7V6z">
                            </path>
                        </svg>
                        Joined October 2023
                    </span>
                </div>
                <div id="follow-following-container"></div>
               
            </div>
        </div>


    <!-- Profile Tabs Navigation -->
    <nav class="flex border-b border-gray-800">
      <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
        <span class="font-bold text-[15px] pb-3 border-b-4 border-[#1d9bf0]">Posts</span>
      </div>
      <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
        <span class="text-[#71767b] font-medium text-[15px] pb-3">Replies</span>
      </div>
      <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
        <span class="text-[#71767b] font-medium text-[15px] pb-3">Highlights</span>
      </div>
      <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
        <span class="text-[#71767b] font-medium text-[15px] pb-3">Media</span>
      </div>
      <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
        <span class="text-[#71767b] font-medium text-[15px] pb-3">Affiliates</span>
      </div>
    </nav>

        <div id="feed-container"></div>
   

  </main>

</body>

    <script>

        const username = "<%= username %>"


 async function getUserProfile() {
        const res = await fetch(`/api/user/get-profile/${username}`, {
            method: "GET",
            headers: {
                authorization: `Bearer ${localStorage.getItem("accessToken")}`
            }
        })

        const data = await res.json();


        console.log(data, "user profile")

        const followers = document.getElementById("followers");
        const followings = document.getElementById("followings");
        const bio = document.getElementById("bio");
        const joined = document.getElementById("joined");
        const profileImage = document.getElementById("profile-image")
        const bannerImage = document.getElementById("banner-image");
        const usernameBody = document.getElementById("username")

        profileImage.src = `/${data.profileData.profile_photo_url}`;
        bannerImage.src = `/${data.profileData.cover_image_url}`;

        bio.innerText = data.profileData.bio;
       

        joined.innerText = data.profileData.created_at

        usernameBody.innerText = data.profileData.username



        const followFollowingContainer = document.getElementById("follow-following-container");
        const followFollowingDiv = document.createElement("div")
        const followFollowingContent = ` <div class="flex gap-5 mt-3 text-[14px]">
                    <a href="/followings/${username}">
                    <button class="hover:underline"><span id="followings" class="font-bold text-white">${data.profileData.followings}</span> <span 
                            class="text-[#71767b]">Following</span></button>
                        </a>
                        <a href="/followers/${username}">
                    <button class="hover:underline"><span id="followers" class="font-bold text-white">${data.profileData.followers}</span> <span
                            class="text-[#71767b]">Followers</span></button>
                            </a>
                </div>`

                followFollowingDiv.innerHTML = followFollowingContent

                followFollowingContainer.append(followFollowingDiv)



    }

    getUserProfile();


    //get user tweets


    async function getUserTweets(){

            const res = await fetch(`/api/user/get-user-tweets/${username}`,{
                method:"GET",
                headers:{
                    "Content-Type": "application/json",
                    "authorization": `Bearer ${localStorage.getItem("accessToken")}`
                },
                

            })


            const data = await res.json();

            if(data.error){
                alert(data.error);
                window.location.href = "/login"
            }

            console.log(data.tweets,"user feed")

            const feedContainer = document.getElementById("feed-container")
           


            for(let i=0;i<data.tweets.userOriginalTweets.length;i++){
                let tweet = data.tweets.userOriginalTweets[i];
                 const mediaHtml = tweet.media && tweet.media.length > 0 
        ? tweet.media.map(item => `
            <img src="${item}" class="w-full h-auto object-cover border-b border-gray-800 last:border-b-0">
          `).join('')
        : '';

                console.log(mediaHtml,"this is media html")


                let feedDiv = document.createElement("div")
                let feedContent = `<article class="p-4 border-b border-gray-800 hover:bg-white/5 transition cursor-pointer">
                <div class="flex gap-3">
                   <a href="/profile/${tweet.username}"> <img src="${tweet.profile_photo_url}" class="w-10 h-10 rounded-full bg-gray-700"></a>
                    <div class="flex-1">
                        <div class="flex items-center gap-1">
                            <a href="/profile/${tweet.username}"><span class="font-bold hover:underline">${tweet.username}</span></a>
                            <span class="text-gray-500">@${tweet.username}· 6h</span>
                        </div>
                        <a href="/tweet/${tweet.tweet_id}">
                        <p class="mt-1 mb-3">${tweet.tweet_content}</p>
                        <div class="rounded-2xl border border-gray-800 overflow-hidden">
                            <div class="rounded-2xl border border-gray-800 overflow-hidden flex flex-col">
                        ${mediaHtml}
                    </div>
                        </div>
                        </a>
                        <!-- Post Actions -->
                        <div class="flex justify-between mt-4 text-gray-500 max-w-md">
                            <div class="flex items-center gap-2 group"><span class="p-2 rounded-full group-hover:bg-blue-500/10 group-hover:text-blue-500">💬</span> ${tweet.reply_count}</div>
                            <div class="flex items-center gap-2 group"><span class="p-2 rounded-full group-hover:bg-green-500/10 group-hover:text-green-500">🔁</span> ${tweet.retweet_count}</div>
                            <div class="flex items-center gap-2 group"><span class="p-2 rounded-full group-hover:bg-pink-500/10 group-hover:text-pink-500">❤️</span> ${tweet.like_count}</div>
                            <div class="flex items-center gap-2 group"><span class="p-2 rounded-full group-hover:bg-blue-500/10 group-hover:text-blue-500">📊</span> 418k</div>
                        </div>
                    </div>
                </div>
            </article>`
            feedDiv.innerHTML = feedContent
            feedContainer.append(feedDiv)
            }




        }

        getUserTweets();

    </script>





</html>
