<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot password / X</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Toastify for notifications -->
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net">
  <script type="text/javascript" src="https://cdn.jsdelivr.net"></script>
  <style>
    @import url('https://cdn.googleapis.com');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-black text-white min-h-screen flex flex-col antialiased">

  <!-- Top Navigation Bar -->
  <header class="flex items-center px-4 py-3 sticky top-0 bg-black/80 backdrop-blur-md z-50">
    <div class="flex-1 flex justify-center">
      <svg viewBox="0 0 24 24" class="h-8 w-8 fill-white">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
      </svg>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col items-center justify-start pt-12 px-6">
    <div class="w-full max-w-[364px] flex flex-col">

      <h1 class="text-[31px] font-bold mb-3 tracking-tight">Find your X account</h1>
      <p class="text-[#71767b] text-[15px] mb-8 leading-5">
        Enter the email associated with your account to change your password.
      </p>

      <form id="forgotForm" class="flex flex-col gap-6">
        <!-- Email Input with Floating Label -->
        <div class="relative w-full border border-gray-800 rounded-[4px] focus-within:ring-1 focus-within:ring-[#1d9bf0] focus-within:border-[#1d9bf0] transition-shadow group">
          <input type="email" id="emailInput" name="email" required
            class="w-full bg-black px-3 pt-6 pb-2 text-white text-[17px] focus:outline-none peer placeholder-transparent"
            placeholder="Email address">
          <label for="emailInput" class="absolute left-3 top-4 text-[#71767b] text-[17px] transition-all pointer-events-none
                        peer-placeholder-shown:top-4 peer-placeholder-shown:text-[17px] 
                        peer-focus:top-1.5 peer-focus:text-[13px] peer-focus:text-[#1d9bf0]
                        peer-not-placeholder-shown:top-1.5 peer-not-placeholder-shown:text-[13px]">
            Email address
          </label>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col gap-3 mt-4">
            <button type="button" id="submitBtn"
                class="w-full bg-white text-black font-bold py-2.5 rounded-full hover:bg-[#d7dbdc] active:scale-[0.98] transition-all duration-200">
                submit
            </button>
            
            <a href="/login" class="w-full text-center border border-gray-700 text-white font-bold py-2 rounded-full hover:bg-white/10 transition-colors text-[15px]">
                Cancel
            </a>
        </div>
      </form>
    </div>
  </main>
  </body>

  <script>
    const forgotForm = document.getElementById('forgotForm');

    const submitBtn = document.getElementById("submitBtn")

    

    submitBtn.addEventListener("click",forgotPass)

    async function forgotPass(e){

        if(!validateForm()){
          e.preventDefault();
          console.log("prevented form submission")
          return;
        }
        
        const formData = new FormData(forgotForm)
        const values = Object.fromEntries(formData.entries())
        console.log(formData)
        console.log(values);
       

        const res = await fetch("/api/auth/forgot-password",{
            method:"POST",
            headers: {
                "Content-Type": "application/json"
            },
            body:JSON.stringify(values)
        })

        const data1 = await res.json();

        const token = data1.data.token

        if(data1.error){
            alert(data1.error);
        }else{
           window.open(`http://localhost:5000/email?token=${token}`);
           window.location.href = `/verify-otp?token=${token}`
        }

        console.log(data1);


    }
    function validateForm(){
    return true;
  }
    
  </script>

</html>
