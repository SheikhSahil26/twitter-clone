            ? "font-bold text-[15px] pb-3 border-b-4 border-[#1d9bf0]"
            : "text-[#71767b] font-medium text-[15px] pb-3"
    }

    function renderPostsTab() {
        setActiveTab("posts")
        renderTweets(ownProfileTweetsData.userOriginalTweets)
    }

    function renderRepliesTab() {
        setActiveTab("replies")
        renderTweets(ownProfileTweetsData.userReplies)
    }

    function renderRetweetsTab() {
        setActiveTab("retweets")
        renderTweets(ownProfileTweetsData.userRetweets)
    }

    function renderTweets(tweets) {
        feedContainer.innerHTML = ""

        for(let i=0;i<tweets.length;i++){
            let tweet = tweets[i];
             const mediaHtml = tweet.media && tweet.media.length > 0 
    ? tweet.media.map(item => `
        <img src="${item}" class="w-full h-auto object-cover border-b border-gray-800 last:border-b-0">
      `).join('')
    : '';

            console.log(mediaHtml,"this is media html")

            const isLiked = Boolean(Number(tweet.is_liked));
            const likeColorClass = isLiked ? "text-pink-500" : "";

            let feedDiv = document.createElement("div")
            let feedContent = `<article class="p-4 border-b border-gray-800 hover:bg-white/5 transition cursor-pointer">
            <div class="flex gap-3">
               <a href="/profile/${tweet.username}"> <img src="${tweet.profile_photo_url}" class="w-10 h-10 rounded-full bg-gray-700"></a>
                <div class="flex-1">
                    <div class="flex items-center gap-1">
                        <a href="/profile/${tweet.username}"><span class="font-bold hover:underline">${tweet.username}</span></a>
                        <span class="text-gray-500">@${tweet.username}· 6h</span>
                        <span class="text-gray-500">
  @${tweet.username} · ${timeAgo(tweet.created_at)}
</span>
                    </div>
                    <a href="/tweet/${tweet.tweet_id}">
                    <p class="mt-1 mb-3">${tweet.tweet_content}</p>
                    <div class="rounded-2xl border border-gray-800 overflow-hidden">
                        <div class="rounded-2xl border border-gray-800 overflow-hidden flex flex-col">
                    ${mediaHtml}
                </div>
                    </div>
                    
                    <!-- Post Actions -->
                    <div class="flex justify-between mt-4 text-gray-500 max-w-md">
                        <div  class="flex items-center gap-2 group"><span onclick="replyToTweet(${tweet.tweet_id})" class="p-2 rounded-full group-hover:bg-blue-500/10 group-hover:text-blue-500">💬</span> ${tweet.reply_count}</div>
                        </a>
                        <div data-retweet-action="${tweet.tweet_id}" class="flex items-center gap-2 group"><span onclick="retweet(event, ${tweet.tweet_id})" class="p-2 rounded-full group-hover:bg-green-500/10 group-hover:text-green-500">🔁</span> <span data-retweet-count="${tweet.tweet_id}">${tweet.retweet_count}</span></div>
                        <div data-like-action="${tweet.tweet_id}" class="flex items-center gap-2 group ${likeColorClass}" style="${isLiked ? 'color:#ec4899;' : ''}"><span onclick="likeTweet(event, ${tweet.tweet_id})" data-like-button="${tweet.tweet_id}" class="p-2 rounded-full cursor-pointer group-hover:bg-pink-500/10 group-hover:text-pink-500" style="${isLiked ? 'color:#ec4899;' : ''}">❤️</span> <span data-like-count="${tweet.tweet_id}" style="${isLiked ? 'color:#ec4899;' : ''}">${tweet.like_count}</span></div>
                        <div class="flex items-center gap-2 group"><span class="p-2 rounded-full group-hover:bg-blue-500/10 group-hover:text-blue-500">📊</span> 418k</div>
                    </div>
                </div>
            </div>
        </article>`
        feedDiv.innerHTML = feedContent
        feedContainer.append(feedDiv)
        }
    }



    async function getUserTweets(){

