<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile / X</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://cdn.googleapis.com');

        body {
            font-family: 'Inter', sans-serif;
        }

        /* Custom scrollbar for dark theme */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #000;
        }

        ::-webkit-scrollbar-thumb {
            background: #2f3336;
            border-radius: 4px;
        }
    </style>
</head>

<body class="bg-black text-white min-h-screen antialiased flex justify-center">

    <!-- Main Container (Centered like X Desktop) -->
    <main class="w-full max-w-[600px] border-x border-gray-800 min-h-screen pb-20">

        <!-- Top Header -->
        <header class="flex items-center px-4 py-1 sticky top-0 bg-black/80 backdrop-blur-md z-40">
            <div class="p-2 hover:bg-white/10 rounded-full cursor-pointer transition-colors mr-6">
                <svg viewBox="0 0 24 24" class="h-5 w-5 fill-white">
                    <path d="M7.414 13l5.043 5.04-1.414 1.42L3.586 12l7.457-7.46 1.414 1.42L7.414 11H21v2H7.414z">
                    </path>
                </svg>
            </div>
            <div>
                <h2 id="username-big" class="text-xl font-bold leading-tight"></h2>
                <p class="text-[13px] text-[#71767b]">0 Posts</p>
            </div>
        </header>

        <!-- Banner Image -->
        <div class="h-48 w-full bg-[#333639] relative">
            <!-- Replace src with actual banner URL -->
            <img src="https://unsplash.com" id="banner-image" class="w-full h-full object-cover" alt="Banner">
        </div>

        <!-- Profile Info Section -->
        <div class="px-4 relative mb-4">
            <!-- Profile Picture -->
            <div class="absolute -top-16 left-4">
                <div class="h-32 w-32 rounded-full border-4 border-black bg-[#16181c] overflow-hidden">
                    <img id="profile-image" src="https://twimg.com" alt="Avatar" class="w-full h-full">
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex justify-end pt-3">
                <button
                    class="bg-black border border-gray-600 px-4 py-1.5 rounded-full font-bold text-[15px] hover:bg-white/10 transition-colors">
                    Edit profile
                </button>
            </div>

            <!-- Bio & Stats -->
            <div class="mt-8">
                <div>
                    <h1 id="username" class="text-xl font-extrabold leading-tight"></h1>
                    <p id="uname" class="text-[#71767b]">@username</p>
                </div>

                <div id="bio" class="mt-3 text-[15px] leading-normal">
                    <span
                        class="text-[#1d9bf0]"></span>
                </div>

                <div  class="flex flex-wrap gap-x-4 gap-y-1 mt-3 text-[#71767b] text-[15px]">
                    <span id="joined" class="flex items-center gap-1">
                        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                            <path
                                d="M7 4V3h2v1h6V3h2v1h1.5C19.88 4 21 5.12 21 6.5v12c0 1.38-1.12 2.5-2.5 2.5h-13C4.12 21 3 19.88 3 18.5v-12C3 5.12 4.12 4 5.5 4H7zm0 2H5.5c-.28 0-.5.22-.5.5v12c0 .28.22.5.5.5h13c.28 0 .5-.22.5-.5v-12c0-.28-.22-.5-.5-.5H17v1h-2V6H9v1H7V6z">
                            </path>
                        </svg>
                        Joined October 2023
                    </span>
                </div>


                <div id="follow-following-container"></div>
               
            </div>
        </div>

        

        <!-- Edit Profile Modal -->
        <div id="editModal"
            class="fixed inset-0 z-[60] hidden flex items-center justify-center bg-[#242d34]/50 backdrop-blur-sm px-4">
            <div
                class="bg-black w-full max-w-[600px] rounded-2xl flex flex-col h-fit max-h-[90vh] overflow-hidden border border-gray-800">

                <!-- Modal Header -->
                <div class="flex items-center justify-between px-4 py-3 sticky top-0 bg-black/80 backdrop-blur-md">
                    <div class="flex items-center gap-8">
                        <button id="closeModal" class="p-2 hover:bg-white/10 rounded-full transition-colors">
                            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-white">
                                <path
                                    d="M10.59 12L4.54 5.96l1.42-1.42L12 10.59l6.04-6.05 1.42 1.42L13.41 12l6.05 6.04-1.42 1.42L12 13.41l-6.04 6.05-1.42-1.42L10.59 12z">
                                </path>
                            </svg>
                        </button>
                        <h2 class="text-xl font-bold">Edit profile</h2>
                    </div>
                    <button id="saveProfile" type="button"
                        class="bg-white text-black px-4 py-1.5 rounded-full font-bold text-[15px] hover:bg-[#d7dbdc] transition-colors">
                        Save
                    </button>
                </div>

                <!-- Scrollable Form Body -->
                <form id="editProfileForm" class="flex-1 overflow-y-auto p-4 flex flex-col gap-6">

                    <!-- File Input 1: Banner -->
                    <div class="relative group">
                        <p class="text-[#71767b] text-sm mb-2">Banner Image</p>
                        <label
                            class="flex flex-col items-center justify-center w-full h-32 border border-gray-800 rounded-lg cursor-pointer hover:bg-white/5 transition-colors">
                            <input type="file" name="cover_image_url" class="hidden" accept="image/*">
                            <svg viewBox="0 0 24 24" class="h-6 w-6 fill-[#1d9bf0]">
                                <path
                                    d="M3 5.5C3 4.119 4.119 3 5.5 3h13C19.881 3 21 4.119 21 5.5v13c0 1.381-1.119 2.5-2.5 2.5h-13C4.119 21 3 19.881 3 18.5v-13zM5.5 5c-.276 0-.5.224-.5.5v9.086l3-3 3 3 5-5 3 3V5.5c0-.276-.224-.5-.5-.5h-13z">
                                </path>
                            </svg>
                        </label>
                    </div>

                    <!-- File Input 2: Profile Photo -->
                    <div class="relative group">
                        <p class="text-[#71767b] text-sm mb-2">Profile Photo</p>
                        <label
                            class="flex items-center justify-center w-24 h-24 border border-gray-800 rounded-full cursor-pointer hover:bg-white/5 transition-colors">
                            <input type="file" name="profile_photo_url" class="hidden" accept="image/*">
                            <svg viewBox="0 0 24 24" class="h-6 w-6 fill-[#1d9bf0]">
                                <path
                                    d="M12 11.5c1.93 0 3.5-1.57 3.5-3.5S13.93 4.5 12 4.5 8.5 6.07 8.5 8s1.57 3.5 3.5 3.5zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2c0-2.33-4.67-3.5-7-3.5z">
                                </path>
                            </svg>
                        </label>
                    </div>

                    <!-- Bio Textarea -->
                    <div
                        class="relative w-full border border-gray-800 rounded-[4px] focus-within:ring-1 focus-within:ring-[#1d9bf0] focus-within:border-[#1d9bf0] transition-shadow">
                        <textarea name="bio" rows="3" required
                            class="w-full bg-black px-3 pt-6 pb-2 text-white text-[17px] focus:outline-none peer placeholder-transparent resize-none"></textarea>
                        <label
                            class="absolute left-3 top-1.5 text-[#71767b] text-[13px] peer-placeholder-shown:top-4 peer-placeholder-shown:text-[17px] peer-focus:top-1.5 peer-focus:text-[13px] peer-focus:text-[#1d9bf0] transition-all">Bio</label>
                    </div>

                    <!-- Date of Birth -->
                    <div
                        class="relative w-full border border-gray-800 rounded-[4px] focus-within:ring-1 focus-within:ring-[#1d9bf0] focus-within:border-[#1d9bf0] transition-shadow">
                        <input type="date" name="dob" required
                            class="w-full bg-black px-3 pt-6 pb-2 text-white text-[17px] focus:outline-none peer color-white [color-scheme:dark]">
                        <label class="absolute left-3 top-1.5 text-[#1d9bf0] text-[13px]">Birth date</label>
                    </div>

                </form>
            </div>
        </div>


        <!-- Profile Tabs Navigation -->
        <nav class="flex border-b border-gray-800">
            <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
                <span class="font-bold text-[15px] pb-3 border-b-4 border-[#1d9bf0]">Posts</span>
            </div>
            <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
                <span class="text-[#71767b] font-medium text-[15px] pb-3">Replies</span>
            </div>
            <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
                <span class="text-[#71767b] font-medium text-[15px] pb-3">Highlights</span>
            </div>
            <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
                <span class="text-[#71767b] font-medium text-[15px] pb-3">Media</span>
            </div>
            <div class="flex-1 flex flex-col items-center hover:bg-white/10 transition-colors cursor-pointer pt-4">
                <span class="text-[#71767b] font-medium text-[15px] pb-3">Affiliates</span>
            </div>
        </nav>



      <div id="feed-container">
       
        </div>

    </main>

</body>

<script>

    let username=""

    async function getUserProfile() {
        const res = await fetch(`/api/user/get-profile-own`, {
            method: "GET",
            headers: {
                authorization: `Bearer ${localStorage.getItem("accessToken")}`
            }
        })

        const data = await res.json();


        console.log(data, "user profile")
        const bigUsername = document.getElementById("username-big")
        const followers = document.getElementById("followers");
        const followings = document.getElementById("followings");
        const bio = document.getElementById("bio");
        const joined = document.getElementById("joined");
        const profileImage = document.getElementById("profile-image")
        const bannerImage = document.getElementById("banner-image");
        const usernameBody = document.getElementById("username")
        const uname = document.getElementById("uname")
        profileImage.src = `${data.profileData.profile_photo_url}`;
        bannerImage.src = `${data.profileData.cover_image_url}`;

        bio.innerText = data.profileData.bio;
        // followers.innerText = data.profileData.followers
        // followings.innerText = data.profileData.followings

        joined.innerText = data.profileData.created_at

        username.innerText = data.profileData.username

        username = data.profileData.username
        bigUsername.innerText = data.profileData.username
        uname.innerText=`@${data.profileData.username}`


        const followFollowingContainer = document.getElementById("follow-following-container");
        const followFollowingDiv = document.createElement("div")
        const followFollowingContent = ` <div class="flex gap-5 mt-3 text-[14px]">
                    <a href="/followings">
                    <button class="hover:underline"><span id="followings" class="font-bold text-white">${data.profileData.followings}</span> <span 
                            class="text-[#71767b]">Following</span></button>
                        </a>
                        <a href="/followers">
                    <button class="hover:underline"><span id="followers" class="font-bold text-white">${data.profileData.followers}</span> <span
                            class="text-[#71767b]">Followers</span></button>
                            </a>
                </div>`

                followFollowingDiv.innerHTML = followFollowingContent

                followFollowingContainer.append(followFollowingDiv)



    }

    getUserProfile();



    //edit profile script

    const editModal = document.getElementById('editModal');
    const editBtn = document.querySelector('button.bg-black.border-gray-600'); // Selects "Edit profile"
    const closeBtn = document.getElementById('closeModal');
    const saveBtn = document.getElementById('saveProfile');
    const editForm = document.getElementById('editProfileForm');

    // Open Modal
    editBtn.addEventListener('click', () => {
        editModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Stop background scrolling
    });

    // Close Modal
    closeBtn.addEventListener('click', () => {
        editModal.classList.add('hidden');
        document.body.style.overflow = 'auto';
    });




    saveBtn.addEventListener("click",editProfile)

    
    async function editProfile() {
  const editProfileForm = document.getElementById("editProfileForm");
  const formData = new FormData(editProfileForm);

  
  for (let pair of formData.entries()) {
    console.log(pair[0] + ': ' + pair[1]);
  }

  const res = await fetch("/api/user/update-profile", {
    method: "PATCH",
    headers: {
      
      "authorization": `Bearer ${localStorage.getItem("accessToken")}`
    },
    
    body: formData 
  });

  const data = await res.json();
  console.log(data, "profile updated successfully");
}


    // Close on background click
    editModal.addEventListener('click', (e) => {
        if (e.target === editModal) closeBtn.click();
    });


    //user posts 



    async function getUserTweets(){

            const res = await fetch(`/api/user/get-user-tweets`,{
                method:"GET",
                headers:{
                    "Content-Type": "application/json",
                    "authorization": `Bearer ${localStorage.getItem("accessToken")}`
                }
                

            })


            const data = await res.json();

            if(data.error){
                alert(data.error);
                window.location.href = "/login"
            }

            console.log(data.tweets,"user feed")

            const feedContainer = document.getElementById("feed-container")
           


            for(let i=0;i<data.tweets.userOriginalTweets.length;i++){
                let tweet = data.tweets.userOriginalTweets[i];
                 const mediaHtml = tweet.media && tweet.media.length > 0 
        ? tweet.media.map(item => `
            <img src="${item}" class="w-full h-auto object-cover border-b border-gray-800 last:border-b-0">
          `).join('')
        : '';

                console.log(mediaHtml,"this is media html")


                let feedDiv = document.createElement("div")
                let feedContent = `<article class="p-4 border-b border-gray-800 hover:bg-white/5 transition cursor-pointer">
                <div class="flex gap-3">
                   <a href="/profile/${tweet.username}"> <img src="${tweet.profile_photo_url}" class="w-10 h-10 rounded-full bg-gray-700"></a>
                    <div class="flex-1">
                        <div class="flex items-center gap-1">
                            <a href="/profile/${tweet.username}"><span class="font-bold hover:underline">${tweet.username}</span></a>
                            <span class="text-gray-500">@${tweet.username}· 6h</span>
                        </div>
                        <a href="/tweet/${tweet.tweet_id}">
                        <p class="mt-1 mb-3">${tweet.tweet_content}</p>
                        <div class="rounded-2xl border border-gray-800 overflow-hidden">
                            <div class="rounded-2xl border border-gray-800 overflow-hidden flex flex-col">
                        ${mediaHtml}
                    </div>
                        </div>
                        
                        <!-- Post Actions -->
                        <div class="flex justify-between mt-4 text-gray-500 max-w-md">
                            <div  class="flex items-center gap-2 group"><span onclick="replyToTweet(${tweet.tweet_id})" class="p-2 rounded-full group-hover:bg-blue-500/10 group-hover:text-blue-500">💬</span> ${tweet.reply_count}</div>
                            </a>
                            <div  class="flex items-center gap-2 group"><span onclick="retweet(${tweet.tweet_id})" class="p-2 rounded-full group-hover:bg-green-500/10 group-hover:text-green-500">🔁</span> ${tweet.retweet_count}</div>
                            <div class="flex items-center gap-2 group"><span onclick="likeTweet(${tweet.tweet_id})" class="p-2 rounded-full group-hover:bg-pink-500/10 group-hover:text-pink-500">❤️</span> ${tweet.like_count}</div>
                            <div class="flex items-center gap-2 group"><span class="p-2 rounded-full group-hover:bg-blue-500/10 group-hover:text-blue-500">📊</span> 418k</div>
                        </div>
                    </div>
                </div>
            </article>`
            feedDiv.innerHTML = feedContent
            feedContainer.append(feedDiv)
            }




        }

        getUserTweets();


        async function likeTweet(tweetId){
            console.log(tweetId)
            const res = await fetch(`/api/tweet/like-unlike-tweet/${tweetId}`,{
                method:"POST",
                headers:{
                    authorization:`Bearer ${localStorage.getItem("accessToken")}`
                },
               
            })


            const data = await res.json();

            console.log(data,"liked unliked data!!!")


        }


    





</script>





</html>