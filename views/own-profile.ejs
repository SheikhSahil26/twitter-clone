    const coverImagePreview = document.getElementById("cover-image-preview");
    const coverImageIcon = document.getElementById("cover-image-icon");
    const profilePhotoInput = document.getElementById("profile-photo-input");
    const profilePhotoPreview = document.getElementById("profile-photo-preview");
    const profilePhotoIcon = document.getElementById("profile-photo-icon");

    function showImagePreview(input, preview, icon) {
        const file = input.files[0];
        if (!file) return;

        preview.src = URL.createObjectURL(file);
        preview.classList.remove("hidden");
        icon.classList.add("hidden");
        preview.onload = () => URL.revokeObjectURL(preview.src);
    }

    coverImageInput.addEventListener("change", () => {
        showImagePreview(coverImageInput, coverImagePreview, coverImageIcon);
    })

    profilePhotoInput.addEventListener("change", () => {
        showImagePreview(profilePhotoInput, profilePhotoPreview, profilePhotoIcon);
    })

    // Open Modal
    editBtn.addEventListener('click', () => {
        editModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Stop background scrolling
    });

    // Close Modal
    closeBtn.addEventListener('click', () => {
        editModal.classList.add('hidden');
        document.body.style.overflow = 'auto';
    });




    saveBtn.addEventListener("click",editProfile)

    
async function editProfile() {
  const editProfileForm = document.getElementById("editProfileForm");
  const formData = new FormData();
  const selectedFormData = new FormData(editProfileForm);

  
  for (let pair of selectedFormData.entries()) {
    const key = pair[0];
    const value = pair[1];

    if (value instanceof File) {
        if (value.name) {
            formData.append(key, value);
        }
    } else if (value.trim()) {
        formData.append(key, value);
    }
  }

  const res = await fetch("/api/user/update-profile", {
    method: "PATCH",
    headers: {
      
      "authorization": `Bearer ${localStorage.getItem("accessToken")}`
    },
    
    body: formData 
  });

  const data = await res.json();
  console.log(data, "profile updated successfully");
}


    // Close on background click
    editModal.addEventListener('click', (e) => {
        if (e.target === editModal) closeBtn.click();
    });


    //user posts 

    const feedContainer = document.getElementById("feed-container")
    const postsTab = document.getElementById("posts-tab")
    const repliesTab = document.getElementById("replies-tab")
    const retweetsTab = document.getElementById("retweets-tab")
    const postsTabText = document.getElementById("posts-tab-text")
    const repliesTabText = document.getElementById("replies-tab-text")
    const retweetsTabText = document.getElementById("retweets-tab-text")

    postsTab.addEventListener("click", renderPostsTab)
    repliesTab.addEventListener("click", renderRepliesTab)
    retweetsTab.addEventListener("click", renderRetweetsTab)

    function setActiveTab(activeTab) {
        postsTabText.className = activeTab === "posts"
            ? "font-bold text-[15px] pb-3 border-b-4 border-[#1d9bf0]"
            : "text-[#71767b] font-medium text-[15px] pb-3"

