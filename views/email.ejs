<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width='device-width', initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://cdn.googleapis.com');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body>
    this is email page

<div class="max-w-xl mx-auto my-10 p-6 border border-gray-300 rounded-md font-sans">
  
  <!-- Simple Header -->
  <div class="mb-6 pb-4 border-b border-gray-100">
    <h2 class="text-xl font-semibold text-gray-800">Security Verification</h2>
    <p class="text-sm text-gray-500">From: info@x.com</p>
  </div>

  <!-- Content -->
  <div class="space-y-4">
    <p class="text-gray-800">Hello,</p>
    
    <p class="text-gray-600">
      Please enter the code below to verify your identity. This code is valid for 10 minutes.
    </p>

    <!-- Simplified OTP Style -->
    <div class="py-6 text-center">
      <h1 id="otp" class="text-4xl font-mono font-bold tracking-widest text-blue-600 bg-gray-50 inline-block px-6 py-3 rounded border">
        123456
      </h1>
      <p class="text-xs text-gray-500 mt-2">Verification Code</p>
    </div>

    <p class="text-gray-600">
      If you did not request this code, please ignore this message.
    </p>

    <div class="pt-6 text-gray-800">
      <p>Regards,</p>
      <p class="font-medium">The X Team</p>
    </div>
  </div>

  <!-- Minimal Footer -->
  <div class="mt-10 pt-4 border-t border-gray-100 text-xs text-gray-400">
    &copy; 2024 X Corp. 1355 Market St, San Francisco, CA
  </div>
</div>
</body>
<script>

    const resetToken = "<%= token %>";

    async function getOTP() {

        const res = await fetch(`/api/auth/get-otp/${resetToken}`, {
            method: "GET",
        })


        const respData = await res.json();

        if (respData.error) {
            alert(respData.error);
        }

        else {
            const otpEle = document.getElementById("otp")
            console.log(respData.data)
            otpEle.innerText = respData.data.otp
            const expiryTime = new Date(`${respData.data.expiry_time}`).getTime();
            const currentTime = new Date().getTime();

            // Difference in seconds
            const diffInSeconds = Math.floor((expiryTime - currentTime) / 1000);

            console.log(diffInSeconds);

        }



    }
    getOTP();


</script>

</html>