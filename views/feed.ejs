     //timezone conversion 
     
  function convertToLocalTime(utcTime) {
    const date = new Date(utcTime); // SQL timestamp (UTC)
    return date.toLocaleString();   // converts to user's local timezone
  }

  // Example usage:
  const created_at = "2026-05-03T10:30:00Z"; // from DB

  function timeAgo(utcTime) {
    const now = new Date();
    const past = new Date(utcTime);
    const diff = Math.floor((now - past) / 1000);

    if (diff < 60) return "Just now";
    if (diff < 3600) return Math.floor(diff / 60) + "m";
    if (diff < 86400) return Math.floor(diff / 3600) + "h";
    return Math.floor(diff / 86400) + "d";
  }


