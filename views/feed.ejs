    async function likeTweet(event, tweetId) {
        event.stopPropagation();
        event.preventDefault();
        console.log(tweetId)
        const res = await fetch(`/api/tweet/like-unlike-tweet/${tweetId}`, {
            method: "POST",
            headers: {
                authorization: `Bearer ${localStorage.getItem("accessToken")}`
            },

        })

        const data1 = await res.json();

        console.log(data1, "liked unliked data!!!")

        const likeData = data1.data?.data || data1.data?.[0] || data1.data || data1;
        const likedValue = likeData.is_liked ?? likeData.liked ?? likeData.likedStatus;
        const countValue = likeData.like_count ?? likeData.likes_count ?? likeData.likes;

        if (likedValue !== undefined && countValue !== undefined) {
            const isLiked = likedValue === true || likedValue === 1 || likedValue === "1" || likedValue === "true";
            const likedColor = isLiked ? "#ec4899" : "";

            document.querySelectorAll(`[data-like-action="${tweetId}"]`).forEach((likeAction) => {
                likeAction.classList.toggle("text-pink-500", isLiked);
                likeAction.style.color = likedColor;
            })

            document.querySelectorAll(`[data-like-button="${tweetId}"]`).forEach((likeButton) => {
                const likeWrapper = likeButton.parentElement;
                likeButton.classList.toggle("text-pink-500", isLiked);
                likeButton.style.color = likedColor;

                if (likeWrapper) {
                    likeWrapper.classList.toggle("text-pink-500", isLiked);
                    likeWrapper.style.color = likedColor;
                }
            })

            document.querySelectorAll(`[data-like-count="${tweetId}"]`).forEach((likeCount) => {
                likeCount.innerText = countValue;
                likeCount.classList.toggle("text-pink-500", isLiked);
                likeCount.style.color = likedColor;
            })
        }


    }





    let subscribeBtn = document.getElementById("subscribeBtn")

    subscribeBtn.addEventListener("click", () => {
        alert("lawde tera ghar jainga isme!!!")
    })

</script>






</html>
