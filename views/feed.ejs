    async function retweet(event, tweetId) {
        event.stopPropagation();
        event.preventDefault();

        const res = await fetch("/api/tweet/retweet", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                authorization: `Bearer ${localStorage.getItem("accessToken")}`
            },
            body: JSON.stringify({ tweet_id: tweetId })
        })

        const data = await res.json();

        if (data.error) {
            alert(data.error)
            return
        }

        const retweetDeleted = data.message === "retweet deleted"

        document.querySelectorAll(`[data-retweet-action="${tweetId}"]`).forEach((retweetAction) => {
            retweetAction.classList.toggle("text-green-500", !retweetDeleted)
            retweetAction.style.color = retweetDeleted ? "" : "#22c55e"
        })

        document.querySelectorAll(`[data-retweet-count="${tweetId}"]`).forEach((retweetCount) => {
            const currentCount = Number(retweetCount.innerText) || 0
            retweetCount.innerText = retweetDeleted ? Math.max(currentCount - 1, 0) : currentCount + 1
        })
    }

    const postBtnLarge = document.getElementById('post-btn-large');
    const postBtnSmall = document.getElementById('post-btn-small');
    const modal = document.getElementById('post-modal');
    const modalClose = document.getElementById('modal-close');
    const modalCancel = document.getElementById('modal-cancel');
    const modalSubmit = document.getElementById('modal-submit');
    const modalFile = document.getElementById('modal-file');
    const fileName = document.getElementById('file-name');
    const filePreview = document.getElementById('file-preview');
    const modalText = document.getElementById('modal-text');
    const inlinePost = document.getElementById('inline-post');
    const inlineText = document.getElementById('inline-text');

    function openModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modalText.focus();
    }
    function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modalText.value = '';
        modalFile.value = '';
        fileName.textContent = '';
        filePreview.innerHTML = '';
    }

    [postBtnLarge, postBtnSmall].forEach(b => { if (b) b.addEventListener('click', openModal); });
    [modalClose, modalCancel].forEach(b => { if (b) b.addEventListener('click', closeModal); });
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

    modalFile.addEventListener('change', (e) => {
        const f = e.target.files[0];
        fileName.textContent = f ? `${f.name} • ${Math.round(f.size / 1024)} KB` : '';
        filePreview.innerHTML = '';
        if (!f) return;
        if (f.type.startsWith('image/')) {
            const img = document.createElement('img');
            img.src = URL.createObjectURL(f);
            img.className = 'max-h-48 rounded mt-2';
            img.onload = () => URL.revokeObjectURL(img.src);
            filePreview.appendChild(img);
        } else if (f.type.startsWith('video/')) {
            const vid = document.createElement('video');
            vid.src = URL.createObjectURL(f);
            vid.controls = true;
            vid.className = 'max-h-48 rounded mt-2';
            filePreview.appendChild(vid);
        } else {
            const p = document.createElement('p');
            p.textContent = 'Preview not available for this file type.';
            filePreview.appendChild(p);
        }
    });


